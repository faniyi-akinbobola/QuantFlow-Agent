# OpenAI (required)
OPENAI_API_KEY=your_openai_api_key

# Alpha Vantage — technical analysis (required)
ALPHAVANTAGE_KEY=your_alphavantage_key

# EventRegistry — news (required)
NEWSAPI_KEY=your_eventregistry_api_key

# SEC EDGAR identity (required by SEC fair-use policy)
NAME=Your Name or Company
EMAIL=your.email@example.com

# LangSmith tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=QuantFlow-Agent
